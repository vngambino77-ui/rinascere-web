{
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node@3.x"
    },
    "*.js": {
      "runtime": "@vercel/node@3.x"
    }
  },
  "routes": [
    {
      "src": "/api/subir-portada",
      "dest": "/subir-portada.js"
    },
    {
      "src": "/api/eliminar-portada",
      "dest": "/eliminar-portada.js"
    }
  ]
}
