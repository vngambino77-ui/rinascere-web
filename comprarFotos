window.comprarFotos = async function() {

  const seleccionadas = Array.from(document.querySelectorAll("input[type=checkbox]:checked"))
    .map(el => el.value);

  if (seleccionadas.length === 0) {
    alert("Seleccioná fotos");
    return;
  }

  // ✅ GUARDAR PARA DESCARGA
  localStorage.setItem("fotosCompradas", JSON.stringify(seleccionadas));

  const res = await fetch("/api/crearPago", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      fotos: seleccionadas,
      precio: 1500,
      titulo: "Fotos Rinascere"
    })
  });

  const data = await res.json();

  if (data.init_point) {
    window.location.href = data.init_point;
  } else {
    alert("Error en pago");
  }
};
